generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Plan {
  FREE
  STARTER
  PRO
  AGENCY
}

enum Tone {
  FRIENDLY
  PROFESSIONAL
  FORMAL
}

enum KnowledgeType {
  FAQ
  PDF
  URL
}

enum MessageRole {
  USER
  BOT
}

model User {
  id                 String    @id @default(cuid())
  clerkId            String    @unique
  email              String
  name               String
  plan               Plan      @default(FREE)
  onboardingDone     Boolean   @default(false)
  deletedAt          DateTime?
  usageAlertSentAt   DateTime?
  createdAt          DateTime  @default(now())

  bots Bot[]
}

model Bot {
  id             String   @id @default(cuid())
  userId         String
  name           String
  avatar         String?
  greeting       String
  tone           Tone     @default(FRIENDLY)
  fallbackMsg    String
  isActive       Boolean  @default(true)
  widgetColor    String   @default("#4f46e5")
  widgetPosition String   @default("bottom-right")
  leadCapture    Boolean  @default(false)
  createdAt      DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeItems KnowledgeItem[]
  conversations  Conversation[]
}

model KnowledgeItem {
  id         String        @id @default(cuid())
  botId      String
  type       KnowledgeType
  question   String?
  answer     String?
  sourceUrl  String?
  rawText    String?
  embedding  Unsupported("vector(3072)")?
  createdAt  DateTime      @default(now())

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  botId     String
  sessionId String
  leadName  String?
  leadEmail String?
  createdAt DateTime @default(now())

  bot      Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
